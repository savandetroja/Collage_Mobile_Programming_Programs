<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="start"
    android:weightSum="100"
    android:background="#87CEEB"
    tools:context=".TweenAnimationActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="50"
        android:gravity="center">

        <TextView
            android:id="@+id/textView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Animation Demo"
            android:textSize="20sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:layout_weight="10"
        android:orientation="horizontal">
        <Button android:id="@+id/alpha" android:layout_height="wrap_content" android:layout_width="wrap_content" android:text="Alpha"/>
        <Button android:id="@+id/rotate" android:layout_height="wrap_content" android:layout_width="wrap_content" android:text="Rotate"/>
        <Button android:id="@+id/scale" android:layout_height="wrap_content" android:layout_width="match_parent" android:text="Scale"/>
        <Button android:id="@+id/translate" android:layout_height="wrap_content" android:layout_width="match_parent" android:text="Translate"/>
    </LinearLayout>
</LinearLayout>